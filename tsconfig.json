{
	"compilerOptions": {
		"strict": true,
		"lib": ["es2020", "dom"],
		"moduleResolution": "node",
		"target": "es2020",
		"module": "CommonJS",
		"outDir": "dist",
		"esModuleInterop": true,
		"declaration": true
	},

	"include": ["src/*.ts", "src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
